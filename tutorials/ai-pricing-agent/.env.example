# AI Pricing Agent Environment Configuration
# Copy this file to .env and add your actual API keys

# Required: Groq API key for AI processing
# Get your free API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Mapbox API key for location services
# Get your API key at: https://www.mapbox.com/
# If not provided, location features will be disabled
MAPBOX_API_KEY=your_mapbox_api_key_here